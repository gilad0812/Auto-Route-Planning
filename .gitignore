# Data / large binaries (DTM, CHM, LAS point clouds, HELIOS install)
data/*
helios_bin/
*.las

# Python
.venv/
__pycache__/
*.pyc
*.pyo
.env

# Build output — PyInstaller writes build/ and dist/ here
# (BuildRoot in build.ps1 defaults to the repo root)
build/
dist/

# Offline dev kit — wheelhouse + Python installer + repo bundle (~300 MB)
offline_kit/

# Editors / IDEs
.vscode/
.idea/
.claude/

# OS cruft
Thumbs.db
Desktop.ini
.DS_Store
